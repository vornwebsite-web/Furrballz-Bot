# ============================================================
#   Furrballz Bot™ — Environment Variables
#   Copy this file to .env and fill in all values.
#   Never commit your .env file to GitHub.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
TOKEN=

# Your application/client ID
CLIENT_ID=

# Your application client secret (needed for OAuth2 dashboard login)
CLIENT_SECRET=

# ── Database ─────────────────────────────────────────────────
# MongoDB Atlas connection string
# Example: mongodb+srv://user:pass@cluster.mongodb.net/furrballz
MONGO_URI=

# ── Dashboard ────────────────────────────────────────────────
# Port the Express dashboard runs on (Railway uses 3000)
PORT=3000

# A long random string used to sign session cookies
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# The full public URL of your Railway deployment (no trailing slash)
# Example: https://furrballz-bot.up.railway.app
BASE_URL=

# ── Bot Owner ────────────────────────────────────────────────
# Your personal Discord user ID — grants access to /owner commands
OWNER_ID=

# ── Optional: Social Poller APIs ─────────────────────────────
# YouTube Data API v3 key (for YouTube notifiers)
YOUTUBE_API_KEY=

# Twitch API credentials (for Twitch live notifiers)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Instagram and TikTok use scraping — no API keys required by default
