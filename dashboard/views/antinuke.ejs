<%- include('partials/head') %>

<form id="antinuke-form">
<div class="card">
  <div class="card-header"><span class="card-header-icon">☢️</span> Anti-Nuke Protection</div>
  <div class="card-body form-grid">
    <div class="form-group">
      <label>Status</label>
      <select name="enabled">
        <option value="true"  <%= cfg.enabled?'selected':'' %>>🟢 Enabled</option>
        <option value="false" <%= !cfg.enabled?'selected':'' %>>🔴 Disabled</option>
      </select>
    </div>
    <div class="form-group">
      <label>Punishment</label>
      <select name="punishment">
        <option value="ban"     <%= cfg.punishment==='ban'    ?'selected':'' %>>🔨 Ban</option>
        <option value="kick"    <%= cfg.punishment==='kick'   ?'selected':'' %>>👢 Kick</option>
        <option value="strip"   <%= cfg.punishment==='strip'  ?'selected':'' %>>🎭 Strip Roles</option>
        <option value="deowner" <%= cfg.punishment==='deowner'?'selected':'' %>>👑 De-Owner</option>
        <option value="timeout" <%= cfg.punishment==='timeout'?'selected':'' %>>⏰ Timeout 24h</option>
      </select>
    </div>
    <div class="form-group">
      <label>Alert Log Channel</label>
      <select name="logChannelId">
        <option value="">None</option>
        <% channels.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= cfg.logChannelId===c.id?'selected':'' %>>#<%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Detection Window (seconds)</label>
      <input type="number" name="windowSeconds" value="<%= cfg.windowSeconds||10 %>" min="5" max="60">
    </div>
  </div>
  <div class="card-footer">
    <button type="button" class="btn btn-primary" onclick="saveForm('antinuke-form','/guild/<%= guild.id %>/antinuke')">Save Settings</button>
  </div>
</div>
</form>

<div class="card">
  <div class="card-header"><span class="card-header-icon">⚡</span> Action Thresholds <small style="font-weight:400;color:var(--text-muted);font-size:12px">— actions before trigger</small></div>
  <div class="card-body" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px">
    <% var thresholdFields = [
      { key:'channelCreate',label:'Channel Create'},{ key:'channelDelete',label:'Channel Delete'},
      { key:'roleCreate',   label:'Role Create'   },{ key:'roleDelete',   label:'Role Delete'   },
      { key:'ban',          label:'Mass Ban'       },{ key:'kick',         label:'Mass Kick'     },
      { key:'webhookCreate',label:'Webhook Create' },{ key:'roleStrip',    label:'Role Strip'    },
    ]; %>
    <% thresholdFields.forEach(function(f) { %>
    <div class="form-group">
      <label><%= f.label %></label>
      <input type="number" id="th-<%= f.key %>" name="<%= f.key %>" value="<%= cfg.thresholds&&cfg.thresholds[f.key]?cfg.thresholds[f.key]:5 %>" min="1" max="25">
    </div>
    <% }); %>
    <div style="grid-column:1/-1">
      <button type="button" class="btn btn-primary" onclick="saveThresholds('<%= guild.id %>')">Save Thresholds</button>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-header-icon">🛡️</span> Whitelist
    <span class="badge badge-accent" style="margin-left:auto"><%= cfg.whitelist?cfg.whitelist.length:0 %> entries</span>
  </div>
  <div class="card-body">
    <div style="display:flex;gap:8px;margin-bottom:16px">
      <input type="text" id="wl-userid" placeholder="User or Bot ID" style="flex:1;max-width:280px">
      <button class="btn btn-sm btn-primary" onclick="addWhitelist('<%= guild.id %>')">Add to Whitelist</button>
    </div>
    <table class="table">
      <thead><tr><th>User ID</th><th></th></tr></thead>
      <tbody id="whitelist-table">
        <% if (cfg.whitelist&&cfg.whitelist.length) { %>
          <% cfg.whitelist.forEach(function(wlId) { %>
          <tr id="wl-row-<%= wlId %>">
            <td><code><%= wlId %></code></td>
            <td><button class="btn btn-xs btn-danger" onclick="removeWhitelist('<%= guild.id %>','<%= wlId %>')">Remove</button></td>
          </tr>
          <% }); %>
        <% } else { %>
        <tr id="wl-empty"><td colspan="2" class="empty-row">No whitelisted users.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (cfg.actionLog&&cfg.actionLog.length) { %>
<div class="card">
  <div class="card-header"><span class="card-header-icon">📋</span> Recent Alert Log</div>
  <div class="card-body p-0">
    <table class="table">
      <thead><tr><th>User ID</th><th>Action</th><th>Count</th><th>Punishment</th><th>When</th></tr></thead>
      <tbody>
        <% cfg.actionLog.slice().reverse().slice(0,20).forEach(function(a) { %>
        <tr>
          <td><code><%= a.userId %></code></td>
          <td><span class="badge"><%= a.action %></span></td>
          <td><%= a.count %></td>
          <td><span class="badge badge-danger"><%= a.punishment %></span></td>
          <td><%= new Date(a.triggeredAt).toLocaleString() %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<script>
async function saveThresholds(guildId){
  const fields=['channelCreate','channelDelete','roleCreate','roleDelete','ban','kick','webhookCreate','roleStrip'];
  const t={};fields.forEach(f=>{const el=document.getElementById('th-'+f);if(el)t[f]=parseInt(el.value)||5;});
  const res=await fetch('/guild/'+guildId+'/antinuke',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({thresholds:JSON.stringify(t)})});
  const json=await res.json();toast(json.success?'Thresholds saved!':json.error||'Error',json.success?'success':'error');
}
async function addWhitelist(guildId){
  const userId=document.getElementById('wl-userid').value.trim();if(!userId)return toast('Enter a user ID.','error');
  const res=await fetch('/guild/'+guildId+'/antinuke/whitelist',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({userId})});
  const json=await res.json();
  if(json.success){
    toast('Added.','success');
    const empty=document.getElementById('wl-empty');if(empty)empty.remove();
    const tbody=document.getElementById('whitelist-table');
    const row=document.createElement('tr');row.id='wl-row-'+userId;
    row.innerHTML='<td><code>'+userId+'</code></td><td><button class="btn btn-xs btn-danger" onclick="removeWhitelist(\''+guildId+'\',\''+userId+'\')">Remove</button></td>';
    tbody.appendChild(row);document.getElementById('wl-userid').value='';
  }else toast(json.error||'Error','error');
}
async function removeWhitelist(guildId,userId){
  const res=await fetch('/guild/'+guildId+'/antinuke/whitelist/'+userId,{method:'DELETE'});
  const json=await res.json();
  if(json.success){toast('Removed.','success');const r=document.getElementById('wl-row-'+userId);if(r)r.remove();}
  else toast(json.error||'Error','error');
}
</script>

<%- include('partials/foot') %>
