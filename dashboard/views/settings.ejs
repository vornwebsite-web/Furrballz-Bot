<%- include('partials/head') %>

<div class="tabs">
  <button class="tab active" data-tab="general">⚙️ General</button>
  <button class="tab" data-tab="economy">💰 Economy</button>
  <button class="tab" data-tab="danger">⚠️ Danger Zone</button>
</div>

<div class="tab-panel active" id="tab-general">
<form id="settings-general-form">
<div class="card">
  <div class="card-header"><span class="card-header-icon">⚙️</span> General Settings</div>
  <div class="card-body form-grid">
    <div class="form-group">
      <label>Bot Prefix <small>Legacy fallback</small></label>
      <input type="text" name="prefix" value="<%= guildDoc.prefix||'!' %>" maxlength="5">
    </div>
    <div class="form-group">
      <label>Mute Role</label>
      <select name="muteRoleId">
        <option value="">None</option>
        <% roles.forEach(function(r) { %>
        <option value="<%= r.id %>" <%= guildDoc.muteRoleId===r.id?'selected':'' %>><%= r.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Suggestion Channel</label>
      <select name="suggestionChannelId">
        <option value="">None</option>
        <% channels.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= guildDoc.suggestionChannelId===c.id?'selected':'' %>>#<%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Birthday Channel</label>
      <select name="birthdayChannelId">
        <option value="">None</option>
        <% channels.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= guildDoc.birthdayChannelId===c.id?'selected':'' %>>#<%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Birthday Role</label>
      <select name="birthdayRoleId">
        <option value="">None</option>
        <% roles.forEach(function(r) { %>
        <option value="<%= r.id %>" <%= guildDoc.birthdayRoleId===r.id?'selected':'' %>><%= r.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Partner Channel</label>
      <select name="partnerChannelId">
        <option value="">None</option>
        <% channels.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= guildDoc.partnerChannelId===c.id?'selected':'' %>>#<%= c.name %></option>
        <% }); %>
      </select>
    </div>
  </div>
  <div class="card-footer">
    <button type="button" class="btn btn-primary" onclick="saveForm('settings-general-form','/guild/<%= guild.id %>/settings/general')">Save Changes</button>
  </div>
</div>
</form>
</div>

<div class="tab-panel" id="tab-economy">
<form id="settings-economy-form">
<div class="card">
  <div class="card-header"><span class="card-header-icon">💰</span> Economy Settings</div>
  <div class="card-body form-grid">
    <div class="form-group">
      <label>Status</label>
      <select name="enabled">
        <option value="true"  <%= guildDoc.economy&&guildDoc.economy.enabled!==false?'selected':'' %>>🟢 Enabled</option>
        <option value="false" <%= guildDoc.economy&&guildDoc.economy.enabled===false?'selected':'' %>>🔴 Disabled</option>
      </select>
    </div>
    <div class="form-group">
      <label>Currency Emoji</label>
      <input type="text" name="currencyEmoji" value="<%= guildDoc.economy&&guildDoc.economy.currencyEmoji?guildDoc.economy.currencyEmoji:'🪙' %>" maxlength="8">
    </div>
    <div class="form-group">
      <label>Daily Reward</label>
      <input type="number" name="dailyAmount" value="<%= guildDoc.economy&&guildDoc.economy.dailyAmount?guildDoc.economy.dailyAmount:100 %>" min="1">
    </div>
    <div class="form-group">
      <label>Starting Balance</label>
      <input type="number" name="startingBalance" value="<%= guildDoc.economy&&guildDoc.economy.startingBalance?guildDoc.economy.startingBalance:0 %>" min="0">
    </div>
    <div class="form-group">
      <label>Work Min</label>
      <input type="number" name="workMin" value="<%= guildDoc.economy&&guildDoc.economy.workMin?guildDoc.economy.workMin:50 %>" min="1">
    </div>
    <div class="form-group">
      <label>Work Max</label>
      <input type="number" name="workMax" value="<%= guildDoc.economy&&guildDoc.economy.workMax?guildDoc.economy.workMax:200 %>" min="1">
    </div>
  </div>
  <div class="card-footer">
    <button type="button" class="btn btn-primary" onclick="saveForm('settings-economy-form','/guild/<%= guild.id %>/settings/economy')">Save Changes</button>
  </div>
</div>
</form>
</div>

<div class="tab-panel" id="tab-danger">
<div class="card" style="border-color:rgba(255,71,87,.3)">
  <div class="card-header" style="color:var(--error)"><span class="card-header-icon">⚠️</span> Danger Zone</div>
  <div class="card-body" style="display:flex;flex-direction:column;gap:12px">
    <% var sections = [
      { key:'welcome',  label:'Reset Welcome Config',   desc:'Disables welcome messages and clears all settings.' },
      { key:'automod',  label:'Reset Automod Config',   desc:'Disables all filters and clears banned word list.' },
      { key:'leveling', label:'Reset Leveling Config',  desc:'Resets XP rates. Does not delete user XP data.' },
      { key:'economy',  label:'Reset Economy Config',   desc:'Resets daily/work amounts. Does not delete balances.' },
      { key:'starboard',label:'Reset Starboard Config', desc:'Disables starboard and clears channel.' },
      { key:'counting', label:'Reset Counting Config',  desc:'Disables counting and resets count to 0.' },
    ]; %>
    <% sections.forEach(function(s) { %>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 18px;background:var(--bg-raised);border-radius:var(--radius-md);border:1px solid var(--border)">
      <div>
        <strong style="font-size:13px"><%= s.label %></strong>
        <p style="font-size:12px;color:var(--text-muted);margin-top:2px"><%= s.desc %></p>
      </div>
      <button class="btn btn-sm btn-danger" style="margin-left:16px" onclick="resetSection('<%= guild.id %>','<%= s.key %>')">Reset</button>
    </div>
    <% }); %>
  </div>
</div>
</div>

<script>
async function resetSection(guildId, section) {
  if (!confirm('Reset '+section+' settings to defaults?')) return;
  const res  = await fetch('/guild/'+guildId+'/settings/reset',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({section})});
  const json = await res.json();
  toast(json.success?(json.message||section+' reset.'):json.error||'Error',json.success?'success':'error');
}
</script>

<%- include('partials/foot') %>
