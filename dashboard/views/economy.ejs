<%- include('partials/head') %>

<div class="tabs">
  <button class="tab active" data-tab="shop">🛒 Shop</button>
  <button class="tab" data-tab="balances">💰 Balances</button>
</div>

<div class="tab-panel active" id="tab-shop">
  <div class="card">
    <div class="card-header">
      <span class="card-header-icon">🛒</span> Shop Items
      <button class="btn btn-sm btn-primary" style="margin-left:auto" onclick="showAddItem()">+ Add Item</button>
    </div>
    <div class="card-body p-0">
      <table class="table">
        <thead><tr><th>Name</th><th>Price</th><th>Type</th><th>Stock</th><th>Sold</th><th></th></tr></thead>
        <tbody>
          <% items.forEach(function(item) { %>
          <tr>
            <td><strong><%= item.name %></strong></td>
            <td><span class="badge badge-accent"><%= item.price.toLocaleString() %></span></td>
            <td><span class="badge"><%= item.type %></span></td>
            <td><%= item.stock === -1 ? '∞' : item.stock %></td>
            <td><%= item.sold %></td>
            <td><button class="btn btn-xs btn-danger" onclick="deleteItem('<%= guild.id %>','<%= item._id %>',this)">Remove</button></td>
          </tr>
          <% }); %>
          <% if (!items.length) { %><tr><td colspan="6" class="empty-row">No items in shop yet.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="tab-panel" id="tab-balances">
  <div class="card">
    <div class="card-header"><span class="card-header-icon">💰</span> Top Balances</div>
    <div class="card-body p-0">
      <table class="table">
        <thead><tr><th>#</th><th>User ID</th><th>Balance</th><th>Set Balance</th></tr></thead>
        <tbody>
          <% topUsers.forEach(function(u, i) { %>
          <tr>
            <td><strong style="color:<%= i===0?'#FFD700':i===1?'#C0C0C0':i===2?'#CD7F32':'var(--text-muted)' %>"><%= i===0?'🥇':i===1?'🥈':i===2?'🥉':`#${i+1}` %></strong></td>
            <td><code><%= u.userId %></code></td>
            <td><span class="badge badge-accent"><%= u.balance.toLocaleString() %></span></td>
            <td>
              <div style="display:flex;gap:8px;align-items:center">
                <input type="number" id="bal-<%= u.userId %>" value="<%= u.balance %>" style="width:110px">
                <button class="btn btn-xs btn-primary" onclick="setBalance('<%= guild.id %>','<%= u.userId %>')">Set</button>
              </div>
            </td>
          </tr>
          <% }); %>
          <% if (!topUsers.length) { %><tr><td colspan="4" class="empty-row">No economy data yet.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
