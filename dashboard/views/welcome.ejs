<%- include('partials/head') %>

<div class="tabs">
  <button class="tab active" data-tab="welcome">👋 Welcome</button>
  <button class="tab" data-tab="invites">📨 Invite Tracker</button>
  <button class="tab" data-tab="boost">💎 Boost</button>
</div>

<div class="tab-panel active" id="tab-welcome">
<form id="welcome-form">
<div class="card">
  <div class="card-header"><span class="card-header-icon">👋</span> Welcome Message</div>
  <div class="card-body form-grid">
    <div class="form-group">
      <label>Status</label>
      <select name="enabled">
        <option value="true"  <%= guildDoc.welcome.enabled?'selected':'' %>>🟢 Enabled</option>
        <option value="false" <%= !guildDoc.welcome.enabled?'selected':'' %>>🔴 Disabled</option>
      </select>
    </div>
    <div class="form-group">
      <label>Welcome Channel</label>
      <select name="channelId">
        <option value="">None</option>
        <% channels.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= guildDoc.welcome.channelId===c.id?'selected':'' %>>#<%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Auto Role on Join</label>
      <select name="roleId">
        <option value="">None</option>
        <% roles.forEach(function(r) { %>
        <option value="<%= r.id %>" <%= guildDoc.welcome.roleId===r.id?'selected':'' %>><%= r.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group span-2">
      <label>Welcome Message <small>Variables: {user} {username} {server} {count}</small></label>
      <textarea name="message" rows="3"><%= guildDoc.welcome.message||'Welcome {user} to **{server}**!' %></textarea>
    </div>
    <div class="form-group span-2">
      <label>DM Message <small>Leave empty to disable</small></label>
      <textarea name="dmMessage" rows="2" placeholder="Leave empty to disable DM welcome..."><%= guildDoc.welcome.dmMessage||'' %></textarea>
    </div>
  </div>
  <div class="card-footer">
    <button type="button" class="btn btn-primary" onclick="saveForm('welcome-form','/guild/<%= guild.id %>/welcome')">Save Changes</button>
  </div>
</div>
</form>
</div>

<div class="tab-panel" id="tab-invites">
<form id="invite-form">
<div class="card">
  <div class="card-header"><span class="card-header-icon">📨</span> Invite Join Notifications</div>
  <div class="card-body form-grid">
    <div class="form-group span-2">
      <p class="form-hint">When a member joins, post who invited them and the inviter's total invite count.</p>
    </div>
    <div class="form-group span-2">
      <label>Invite Log Channel</label>
      <select name="inviteLogChannelId">
        <option value="">Disabled</option>
        <% channels.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= guildDoc.inviteLogChannelId===c.id?'selected':'' %>>#<%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group span-2">
      <div style="background:var(--bg-raised);border:1px solid var(--border);border-radius:var(--radius-md);padding:14px 18px;">
        <p style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Preview</p>
        <p style="font-size:13px;color:var(--text-primary)"><strong style="color:var(--accent)">Furrballz Bot™</strong> <span style="font-size:11px;color:var(--text-muted)">Today at 17:39</span></p>
        <p style="font-size:13px;margin-top:4px">@NewUser has been invited by @Inviter and has now <strong>5 invites</strong>.</p>
      </div>
    </div>
  </div>
  <div class="card-footer">
    <button type="button" class="btn btn-primary" onclick="saveInviteLog('<%= guild.id %>')">Save Changes</button>
  </div>
</div>
</form>
</div>

<div class="tab-panel" id="tab-boost">
<form id="boost-form">
<div class="card">
  <div class="card-header"><span class="card-header-icon">💎</span> Boost Announcements</div>
  <div class="card-body form-grid">
    <div class="form-group">
      <label>Boost Announcement Channel</label>
      <select name="boostChannelId">
        <option value="">Disabled</option>
        <% channels.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= guildDoc.boostChannelId===c.id?'selected':'' %>>#<%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Boost Reward Role <small>Auto-assigned when someone boosts</small></label>
      <select name="boostRoleId">
        <option value="">None</option>
        <% roles.forEach(function(r) { %>
        <option value="<%= r.id %>" <%= guildDoc.boostRoleId===r.id?'selected':'' %>><%= r.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group span-2">
      <label>Boost Message <small>Variables: {user} {username} {server} {count}</small></label>
      <input type="text" name="boostMessage" value="<%= guildDoc.boostMessage || '{user} just boosted **{server}**! 💎 We now have **{count}** boosts!' %>">
    </div>
  </div>
  <div class="card-footer">
    <button type="button" class="btn btn-primary" onclick="saveBoost('<%= guild.id %>')">Save Changes</button>
  </div>
</div>
</form>
</div>

<script>
async function saveInviteLog(guildId) {
  const channelId = document.querySelector('#invite-form select[name="inviteLogChannelId"]').value;
  const res  = await fetch('/guild/'+guildId+'/welcome',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({inviteLogChannelId:channelId})});
  const json = await res.json();
  toast(json.success?'Saved!':json.error||'Error',json.success?'success':'error');
}
async function saveBoost(guildId) {
  const channelId = document.querySelector('#boost-form select[name="boostChannelId"]').value;
  const roleId    = document.querySelector('#boost-form select[name="boostRoleId"]').value;
  const message   = document.querySelector('#boost-form input[name="boostMessage"]').value;
  const res  = await fetch('/guild/'+guildId+'/welcome',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({boostChannelId:channelId,boostRoleId:roleId,boostMessage:message})});
  const json = await res.json();
  toast(json.success?'Saved!':json.error||'Error',json.success?'success':'error');
}
</script>

<%- include('partials/foot') %>
