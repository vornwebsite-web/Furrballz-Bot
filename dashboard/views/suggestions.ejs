<%- include('partials/head') %>

<div class="tabs">
  <a href="?status=pending"  class="tab <%= status==='pending' ?'active':'' %>">⏳ Pending</a>
  <a href="?status=approved" class="tab <%= status==='approved'?'active':'' %>">✅ Approved</a>
  <a href="?status=denied"   class="tab <%= status==='denied'  ?'active':'' %>">❌ Denied</a>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-header-icon"><%= status==='pending'?'⏳':status==='approved'?'✅':'❌' %></span>
    <%= status.charAt(0).toUpperCase()+status.slice(1) %> Suggestions
    <span class="badge badge-accent" style="margin-left:auto"><%= docs.length %></span>
  </div>
  <div class="card-body p-0">
    <table class="table">
      <thead>
        <tr>
          <th>Author</th><th>Suggestion</th><th>Votes</th><th>Date</th>
          <% if (status==='pending') { %><th>Actions</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% docs.forEach(function(d) { %>
        <tr>
          <td><code><%= d.authorId %></code></td>
          <td style="max-width:300px"><%= d.content.slice(0,100) %><%= d.content.length>100?'…':'' %></td>
          <td>
            <span class="badge badge-success">👍 <%= d.upvotes %></span>
            <span class="badge badge-danger" style="margin-left:4px">👎 <%= d.downvotes %></span>
          </td>
          <td><%= new Date(d.createdAt).toLocaleDateString() %></td>
          <% if (status==='pending') { %>
          <td>
            <div style="display:flex;gap:6px">
              <button class="btn btn-xs btn-success" onclick="reviewSuggestion('<%= guild.id %>','<%= d._id %>','approve',this)">✅ Approve</button>
              <button class="btn btn-xs btn-danger"  onclick="reviewSuggestion('<%= guild.id %>','<%= d._id %>','deny',this)">❌ Deny</button>
            </div>
          </td>
          <% } %>
        </tr>
        <% }); %>
        <% if (!docs.length) { %><tr><td colspan="5" class="empty-row">No suggestions found.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/foot') %>
