<%- include('partials/head') %>

<div class="feeds-grid">
  <% feeds.forEach(function(f) { %>
  <%
    var ch = null;
    for (var i = 0; i < channels.length; i++) {
      if (channels[i].id === f.channelId) { ch = channels[i]; break; }
    }
  %>
  <div class="feed-card">
    <div class="feed-card-top">
      <span class="feed-platform feed-platform--<%= f.platform %>"><%= f.platform %></span>
      <span class="feed-handle">@<%= f.handle %></span>
      <% if (f.paused) { %><span class="badge badge-warning">Paused</span><% } %>
    </div>
    <div class="feed-card-channel"># <%= ch ? ch.name : 'unknown' %></div>
    <div class="feed-card-actions">
      <button class="btn btn-sm" onclick="toggleFeedPause('<%= guild.id %>','<%= f._id %>',this)"><%= f.paused?'Resume':'Pause' %></button>
      <button class="btn btn-sm btn-danger" onclick="deleteFeed('<%= guild.id %>','<%= f._id %>',this)">Remove</button>
    </div>
  </div>
  <% }); %>
  <% if (!feeds.length) { %>
  <div class="empty-state">
    <div class="empty-icon">📡</div>
    <p>No social feeds configured yet.<br>Use <code>/social add</code> or <code>/twitch add</code> in your server.</p>
  </div>
  <% } %>
</div>

<%- include('partials/foot') %>
