<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('furrballz-theme') || 'dark');</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body { display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--bg-base); }
    .error-card { text-align:center;padding:56px 48px;background:var(--bg-surface);border:1px solid var(--error);border-radius:var(--radius-xl);max-width:480px;width:90%;position:relative;overflow:hidden; }
    .error-card::before { content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--error),#ff8c00); }
    .error-icon { font-size:52px;margin-bottom:16px; }
    .error-title { font-size:22px;font-weight:700;margin-bottom:8px; }
    .error-msg { font-size:13px;color:var(--text-muted);margin-bottom:28px;line-height:1.6;font-family:var(--font-mono);background:var(--bg-raised);border:1px solid var(--border);border-radius:var(--radius-md);padding:12px 16px;text-align:left;word-break:break-all; }
  </style>
</head>
<body>
  <div class="error-card">
    <div class="error-icon">⚠️</div>
    <h1 class="error-title">Something went wrong</h1>
    <p class="error-msg"><%= locals.message || 'An unexpected error occurred.' %></p>
    <a href="/" class="btn btn-primary">Go Home</a>
  </div>
  <script src="/theme.js"></script>
</body>
</html>
