<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — <%= botName %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="login-page">
  <div class="login-card">
    <div class="login-logo">🐾</div>
    <h1 class="login-title"><%= botName %></h1>
    <p class="login-subtitle">Dashboard for TheFurrballz Hotel</p>

    <% if (locals.query && query.error) { %>
      <div class="alert alert-error">Authentication failed. Please try again.</div>
    <% } %>

    <a href="/auth/discord" class="btn btn-discord">
      <svg width="20" height="20" viewBox="0 0 71 55" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-right:8px;vertical-align:middle">
        <path d="M60.1 4.9A58.8 58.8 0 0 0 45.6.4a40.6 40.6 0 0 0-1.8 3.7 54.4 54.4 0 0 0-16.3 0A40.7 40.7 0 0 0 25.6.4 58.7 58.7 0 0 0 11 5C1.6 19.6-1 33.8.3 47.8a59.2 59.2 0 0 0 18 9.1 44.5 44.5 0 0 0 3.8-6.2 38.5 38.5 0 0 1-6-2.9l1.5-1.1a42.2 42.2 0 0 0 36 0l1.5 1.1a38.4 38.4 0 0 1-6 2.9 44.6 44.6 0 0 0 3.8 6.2 59 59 0 0 0 18-9.1C72 31.6 68.1 17.5 60.1 4.9ZM23.7 39.4c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2 6.5 3.3 6.4 7.2c0 4-2.8 7.2-6.4 7.2Zm23.6 0c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2 6.5 3.3 6.4 7.2c0 4-2.9 7.2-6.4 7.2Z" fill="currentColor"/>
      </svg>
      Login with Discord
    </a>

    <p class="login-note">You must have <strong>Manage Server</strong> permission<br>in the server you want to manage.</p>
  </div>
  <script src="/theme.js"></script>
</body>
</html>
